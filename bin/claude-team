#!/usr/bin/env bash
# claude-team — Manage Claude Code team member personas
# https://github.com/code-katz/claude-team-cli

set -euo pipefail

PROFILES_DIR="${CLAUDE_TEAM_PROFILES:-$HOME/.claude/team}"
CLAUDE_MD="$HOME/.claude/CLAUDE.md"
BRANCHES_INDEX="$HOME/.claude/branches/INDEX.md"
MARKER_START="<!-- CLAUDE-TEAM:START -->"
MARKER_END="<!-- CLAUDE-TEAM:END -->"
COORD_START="<!-- CLAUDE-COORDINATOR:START -->"
COORD_END="<!-- CLAUDE-COORDINATOR:END -->"

# ─── Helpers ────────────────────────────────────────────────────────────────

bold()  { printf '\033[1m%s\033[0m' "$*"; }
green() { printf '\033[32m%s\033[0m' "$*"; }
cyan()  { printf '\033[36m%s\033[0m' "$*"; }
dim()   { printf '\033[2m%s\033[0m' "$*"; }
red()   { printf '\033[31m%s\033[0m' "$*"; }

die() { echo "$(red "error:") $*" >&2; exit 1; }

lowercase() { echo "$1" | tr '[:upper:]' '[:lower:]'; }
capitalize() { echo "$1" | awk '{print toupper(substr($0,1,1)) substr($0,2)}'; }

require_profiles_dir() {
  [[ -d "$PROFILES_DIR" ]] || die "Profiles directory not found: $PROFILES_DIR
Run the installer first: bash install.sh"
}

resolve_name() {
  local input
  input=$(lowercase "$1")
  local profile="$PROFILES_DIR/$input.md"
  [[ -f "$profile" ]] || die "No profile found for '$input'. Run 'claude-team list' to see available team members."
  echo "$profile"
}

get_active() {
  [[ -f "$CLAUDE_MD" ]] || { echo ""; return; }
  # Extract the name line from the active block
  awk "/$MARKER_START/,/$MARKER_END/" "$CLAUDE_MD" \
    | grep -m1 '^# ' \
    | sed 's/^# //' \
    | sed 's/ —.*//' \
    || echo ""
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_list() {
  require_profiles_dir
  echo ""
  echo "$(bold "Claude Dev Team") — available members"
  echo ""

  local active
  active=$(get_active)

  for profile in "$PROFILES_DIR"/*.md; do
    [[ -f "$profile" ]] || continue
    local name
    name=$(basename "$profile" .md)
    [[ "$name" == "coordinator" ]] && continue  # coordinator is not a team member
    # Extract the title line (first # heading)
    local title
    title=$(grep -m1 '^# ' "$profile" | sed 's/^# //')
    # Extract the role from the title (after " — ")
    local role
    role=$(echo "$title" | sed 's/.*— //')

    local name_cap
    name_cap=$(capitalize "$name")
    local is_active=false
    if [[ -n "$active" ]]; then
      local active_lower
      active_lower=$(lowercase "$active")
      [[ "$name" == "$active_lower" ]] && is_active=true
    fi
    if [[ "$is_active" == true ]]; then
      printf "  $(green "●") $(bold "%s") — %s $(dim "(active)")\n" "$name_cap" "$role"
    else
      printf "  $(dim "○") $(bold "%s") — %s\n" "$name_cap" "$role"
    fi
  done

  echo ""
  echo "$(dim "Run 'claude-team use <name>' to activate a team member.")"
  echo ""
}

cmd_show() {
  [[ $# -ge 1 ]] || die "Usage: claude-team show <name>"
  local profile
  profile=$(resolve_name "$1")
  echo ""
  cat "$profile"
  echo ""
}

cmd_use() {
  [[ $# -ge 1 ]] || die "Usage: claude-team use <name>"
  local name
  name=$(lowercase "$1")
  local profile
  profile=$(resolve_name "$name")

  # Ensure CLAUDE.md exists
  touch "$CLAUDE_MD"

  local content
  content=$(cat "$profile")

  local block
  block=$(printf '%s\n%s\n%s' "$MARKER_START" "$content" "$MARKER_END")

  if grep -qF "$MARKER_START" "$CLAUDE_MD"; then
    # Replace existing block by splitting around the markers
    local tmp
    tmp=$(mktemp)
    awk "/$MARKER_START/{exit} {print}" "$CLAUDE_MD" > "$tmp"
    printf '%s\n%s\n%s\n' "$MARKER_START" "$content" "$MARKER_END" >> "$tmp"
    awk "/$MARKER_END/{found=1; next} found{print}" "$CLAUDE_MD" >> "$tmp"
    mv "$tmp" "$CLAUDE_MD"
  else
    # Append block
    printf '\n%s\n' "$block" >> "$CLAUDE_MD"
  fi

  local display_name
  display_name=$(grep -m1 '^# ' "$profile" | sed 's/^# //' | sed 's/ —.*//')

  echo ""
  echo "$(green "✓") $(bold "$display_name") is now active."
  echo "$(dim "Start a new Claude Code session to apply the profile.")"
  echo ""
}

cmd_reset() {
  if ! grep -qF "$MARKER_START" "$CLAUDE_MD" 2>/dev/null; then
    echo ""
    echo "$(dim "No team member is currently active.")"
    echo ""
    return
  fi

  local active
  active=$(get_active)

  local tmp
  tmp=$(mktemp)
  awk "/$MARKER_START/{found=1} found && /$MARKER_END/{found=0; next} !found{print}" \
    "$CLAUDE_MD" > "$tmp"
  # Remove trailing blank lines left by removed block
  sed -e 's/[[:space:]]*$//' "$tmp" | \
    awk 'NF{found=1} found' > "$CLAUDE_MD" || true
  rm -f "$tmp"

  echo ""
  if [[ -n "$active" ]]; then
    echo "$(green "✓") $(bold "$active") deactivated."
  else
    echo "$(green "✓") Team member deactivated."
  fi
  echo "$(dim "Start a new Claude Code session to apply.")"
  echo ""
}

cmd_status() {
  local active
  active=$(get_active)

  local coord_on="no"
  if grep -qF "$COORD_START" "$CLAUDE_MD" 2>/dev/null; then
    coord_on="yes"
  fi

  echo ""
  if [[ -n "$active" ]]; then
    echo "$(bold "Active team member:") $(green "$active")"
  else
    echo "$(bold "Active team member:") $(dim "none")"
  fi
  if [[ "$coord_on" == "yes" ]]; then
    echo "$(bold "Coordinator:") $(green "on")"
  else
    echo "$(bold "Coordinator:") $(dim "off")"
  fi
  echo ""
}

cmd_coordinator() {
  local action="${1:-}"
  [[ -n "$action" ]] || die "Usage: claude-team coordinator <on|off>"

  case "$action" in
    on)
      local coord_file="$PROFILES_DIR/coordinator.md"
      [[ -f "$coord_file" ]] || die "Coordinator profile not found: $coord_file
Run the installer first: bash install.sh"

      touch "$CLAUDE_MD"
      local content
      content=$(cat "$coord_file")
      local block
      block=$(printf '%s\n%s\n%s' "$COORD_START" "$content" "$COORD_END")

      if grep -qF "$COORD_START" "$CLAUDE_MD"; then
        # Replace existing coordinator block by splitting around the markers
        local tmp
        tmp=$(mktemp)
        awk "/$COORD_START/{exit} {print}" "$CLAUDE_MD" > "$tmp"
        printf '%s\n%s\n%s\n' "$COORD_START" "$content" "$COORD_END" >> "$tmp"
        awk "/$COORD_END/{found=1; next} found{print}" "$CLAUDE_MD" >> "$tmp"
        mv "$tmp" "$CLAUDE_MD"
        echo ""
        echo "$(green "✓") Coordinator already on — profile refreshed."
      else
        printf '\n%s\n' "$block" >> "$CLAUDE_MD"
        echo ""
        echo "$(green "✓") Coordinator $(bold "on")."
        echo "$(dim "Claude will now proactively suggest team members and mode switches.")"
      fi
      echo "$(dim "Start a new Claude Code session to apply.")"
      echo ""
      ;;

    off)
      if ! grep -qF "$COORD_START" "$CLAUDE_MD" 2>/dev/null; then
        echo ""
        echo "$(dim "Coordinator is already off.")"
        echo ""
        return
      fi

      local tmp
      tmp=$(mktemp)
      awk "/$COORD_START/{found=1} found && /$COORD_END/{found=0; next} !found{print}" \
        "$CLAUDE_MD" > "$tmp"
      sed -e 's/[[:space:]]*$//' "$tmp" | \
        awk 'NF{found=1} found' > "$CLAUDE_MD" || true
      rm -f "$tmp"

      echo ""
      echo "$(green "✓") Coordinator $(bold "off")."
      echo "$(dim "Start a new Claude Code session to apply.")"
      echo ""
      ;;

    *)
      die "Unknown coordinator action: $action. Use 'on' or 'off'."
      ;;
  esac
}

cmd_install_commands() {
  local repo_dir
  # Resolve the repo directory: script lives in bin/, so go one level up
  repo_dir="$(cd "$(dirname "$(readlink "$0" 2>/dev/null || echo "$0")")/.." && pwd)"
  local commands_src="$repo_dir/commands"
  local commands_dst="$HOME/.claude/commands"

  [[ -d "$commands_src" ]] || die "Commands directory not found: $commands_src
Make sure you are running this from the claude-team-cli repo."

  echo ""
  echo "Installing slash commands to $commands_dst ..."
  mkdir -p "$commands_dst"
  cp "$commands_src"/*.md "$commands_dst/"
  echo "$(green "✓") Slash commands installed:"
  for f in "$commands_dst"/*.md; do
    [[ -f "$f" ]] || continue
    local name
    name=$(basename "$f" .md)
    echo "    $(dim "/")$(bold "$name")"
  done
  echo ""
  echo "Use them in any Claude Code session:"
  echo "  $(dim "/robin")   — switch to Robin (Testing)"
  echo "  $(dim "/akira")   — switch to Akira (Backend)"
  echo "  $(dim "/sasha")   — switch to Sasha (Frontend)"
  echo "  $(dim "/toni")    — switch to Toni (Product Marketing)"
  echo "  $(dim "/river")   — switch to River (Product)"
  echo "  $(dim "/team")    — show current team status"
  echo ""
  echo "$(dim "No new session required — switches take effect immediately.")"
  echo ""
}

# ─── Branch helpers ──────────────────────────────────────────────────────────

get_project_name() {
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || die "Not inside a git repository."
  basename "$root"
}

ensure_branches_index() {
  if [[ ! -f "$BRANCHES_INDEX" ]]; then
    mkdir -p "$(dirname "$BRANCHES_INDEX")"
    printf '# Branch Index\n\n| Date | Project | Branch | Plan Slug | Status | Notes |\n|---|---|---|---|---|---|\n' \
      > "$BRANCHES_INDEX"
  fi
}

get_active_branch() {
  local project="$1"
  [[ -f "$BRANCHES_INDEX" ]] || { echo ""; return; }
  awk -F'|' -v proj="$project" \
    '$3 ~ " " proj " " && $6 ~ / active / { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $4); print $4; exit }' \
    "$BRANCHES_INDEX"
}

# ─── Branch commands ──────────────────────────────────────────────────────────

cmd_branch_start() {
  [[ $# -ge 1 ]] || die "Usage: claude-team branch start <branch-name> [--plan <slug>]"
  local branch_name="$1"
  shift
  local plan_slug=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan)
        [[ $# -ge 2 ]] || die "--plan requires a value"
        plan_slug="$2"
        shift 2
        ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  local project
  project=$(get_project_name)

  # Block if an active branch already exists for this project
  local existing
  existing=$(get_active_branch "$project")
  if [[ -n "$existing" ]]; then
    die "Active branch '$(bold "$existing")' already exists for '$project'.
Run 'claude-team branch done' or 'claude-team branch abandon' before starting a new branch."
  fi

  ensure_branches_index

  local today
  today=$(date '+%Y-%m-%d')
  printf '| %s | %s | %s | %s | active | |\n' \
    "$today" "$project" "$branch_name" "$plan_slug" >> "$BRANCHES_INDEX"

  echo ""
  echo "$(green "✓") Branch $(bold "$branch_name") registered for $(bold "$project")."
  [[ -n "$plan_slug" ]] && echo "$(dim "  Linked to plan: $plan_slug")"
  echo "$(dim "  All work this session goes on this branch.")"
  echo ""
}

cmd_branch_close() {
  local new_status="$1"  # "merged" or "abandoned"
  local project
  project=$(get_project_name)

  local active
  active=$(get_active_branch "$project")
  [[ -n "$active" ]] || die "No active branch found for '$project'. Nothing to close."

  local tmp
  tmp=$(mktemp)
  awk -F'|' -v proj="$project" -v ns=" $new_status " '
    $3 ~ " " proj " " && $6 ~ / active / {
      d=$2; sub(/^[[:space:]]+/,"",d); sub(/[[:space:]]+$/,"",d)
      p=$3; sub(/^[[:space:]]+/,"",p); sub(/[[:space:]]+$/,"",p)
      b=$4; sub(/^[[:space:]]+/,"",b); sub(/[[:space:]]+$/,"",b)
      s=$5; sub(/^[[:space:]]+/,"",s); sub(/[[:space:]]+$/,"",s)
      printf "| %s | %s | %s | %s |%s| |\n", d, p, b, s, ns
      next
    }
    { print }
  ' "$BRANCHES_INDEX" > "$tmp" && mv "$tmp" "$BRANCHES_INDEX"

  echo ""
  if [[ "$new_status" == "merged" ]]; then
    echo "$(green "✓") Branch $(bold "$active") marked as merged."
    echo "$(dim "  To delete the local branch:")"
    echo "  git branch -d $active"
    echo "$(dim "  To delete the remote branch:")"
    echo "  git push origin --delete $active"
  else
    echo "$(green "✓") Branch $(bold "$active") marked as abandoned."
    echo "$(dim "  To delete the local branch:")"
    echo "  git branch -D $active"
  fi
  echo ""
}

cmd_branch_done()    { cmd_branch_close "merged"; }
cmd_branch_abandon() { cmd_branch_close "abandoned"; }

cmd_branch_status() {
  local project
  project=$(get_project_name)

  local active
  active=$(get_active_branch "$project")

  echo ""
  if [[ -n "$active" ]]; then
    echo "$(bold "Active branch:") $(green "$active") $(dim "($project)")"
    # Show linked plan if any
    if [[ -f "$BRANCHES_INDEX" ]]; then
      local plan_slug
      plan_slug=$(awk -F'|' -v proj="$project" \
        '$3 ~ " " proj " " && $6 ~ / active / { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $5); print $5; exit }' \
        "$BRANCHES_INDEX")
      [[ -n "$plan_slug" ]] && echo "$(dim "Linked plan:") $plan_slug"
    fi
  else
    echo "$(bold "Active branch:") $(red "none")"
    echo "$(dim "  No branch registered for '$project'.")"
    echo "$(dim "  Start one: claude-team branch start feat/<name>")"
  fi
  echo ""
}

cmd_branch_list() {
  ensure_branches_index
  echo ""
  echo "$(bold "Branch Index")"
  echo ""
  cat "$BRANCHES_INDEX"
  echo ""
  echo "$(dim "Index: $BRANCHES_INDEX")"
  echo ""
}

cmd_branch_guard() {
  local action="${1:-}"
  [[ -n "$action" ]] || die "Usage: claude-team branch guard <install|remove>"

  local git_root
  git_root=$(git rev-parse --show-toplevel 2>/dev/null) || die "Not inside a git repository."
  local hook_file="$git_root/.git/hooks/pre-commit"

  case "$action" in
    install)
      if [[ -f "$hook_file" ]]; then
        grep -q "claude-team" "$hook_file" 2>/dev/null \
          || die "A pre-commit hook already exists at $hook_file (not installed by claude-team). Remove it manually first."
      fi
      local tmp_hook
      tmp_hook=$(mktemp)
      cat > "$tmp_hook" << 'HOOK'
#!/usr/bin/env bash
# Installed by claude-team branch guard
# Blocks accidental direct commits on main/master
branch=$(git rev-parse --abbrev-ref HEAD)
if [[ "$branch" == "main" || "$branch" == "master" ]]; then
  echo "error: direct commits to $branch are not allowed." >&2
  echo "Create a feature branch: git checkout -b feat/<name>" >&2
  exit 1
fi
HOOK
      mv "$tmp_hook" "$hook_file"
      chmod +x "$hook_file"
      echo ""
      echo "$(green "✓") Branch guard installed."
      echo "$(dim "  Direct commits to main/master are now blocked.")"
      echo "$(dim "  Hook: $hook_file")"
      echo ""
      ;;
    remove)
      if [[ ! -f "$hook_file" ]]; then
        echo ""
        echo "$(dim "No pre-commit hook found at $hook_file.")"
        echo ""
        return
      fi
      grep -q "claude-team" "$hook_file" 2>/dev/null \
        || die "Hook at $hook_file was not installed by claude-team. Remove it manually."
      rm "$hook_file"
      echo ""
      echo "$(green "✓") Branch guard removed."
      echo ""
      ;;
    *) die "Unknown guard action: $action. Use 'install' or 'remove'." ;;
  esac
}

cmd_branch() {
  local subcmd="${1:-}"
  [[ -n "$subcmd" ]] || die "Usage: claude-team branch <start|done|abandon|status|list|guard>"
  shift
  case "$subcmd" in
    start)   cmd_branch_start "$@" ;;
    done)    cmd_branch_done ;;
    abandon) cmd_branch_abandon ;;
    status)  cmd_branch_status ;;
    list)    cmd_branch_list ;;
    guard)   cmd_branch_guard "${1:-}" ;;
    *) die "Unknown branch subcommand: $subcmd. Use start|done|abandon|status|list|guard." ;;
  esac
}

cmd_help() {
  echo ""
  echo "$(bold "claude-team") — Manage Claude Code team member personas"
  echo ""
  echo "$(bold "Usage:")"
  echo "  claude-team list                    List all available team members"
  echo "  claude-team show <name>             Display a team member's full profile"
  echo "  claude-team use <name>              Activate a team member in Claude Code"
  echo "  claude-team reset                   Deactivate the current team member"
  echo "  claude-team status                  Show active team member and coordinator state"
  echo "  claude-team coordinator on|off      Enable/disable proactive team check-ins"
  echo "  claude-team install-commands        Install slash commands to ~/.claude/commands/"
  echo ""
  echo "$(bold "Branch hygiene:")"
  echo "  claude-team branch start <name>    Register a branch for the current project"
  echo "  claude-team branch start <name> --plan <slug>"
  echo "                                     Register a branch linked to an archived plan"
  echo "  claude-team branch done            Mark active branch as merged; print delete commands"
  echo "  claude-team branch abandon         Mark active branch as abandoned; print delete commands"
  echo "  claude-team branch status          Show active branch for the current project"
  echo "  claude-team branch list            Show full branch index (~/.claude/branches/INDEX.md)"
  echo "  claude-team branch guard install   Install pre-commit hook blocking commits on main/master"
  echo "  claude-team branch guard remove    Remove the pre-commit hook"
  echo ""
  echo "$(bold "Examples:")"
  echo "  claude-team use robin               Activate Robin (Testing)"
  echo "  claude-team use akira               Activate Akira (Backend)"
  echo "  claude-team use sasha               Activate Sasha (Frontend)"
  echo "  claude-team use toni                Activate Toni (Product Marketing)"
  echo "  claude-team use river               Activate River (Product)"
  echo "  claude-team coordinator on          Enable proactive team suggestions"
  echo "  claude-team reset                   Return to default Claude behavior"
  echo "  claude-team install-commands        Install /robin, /akira, /sasha, /toni, /river, /team"
  echo ""
  echo "$(dim "Profiles are stored in: $PROFILES_DIR")"
  echo "$(dim "Active profile is injected into: $CLAUDE_MD")"
  echo ""
}

# ─── Dispatch ────────────────────────────────────────────────────────────────

case "${1:-help}" in
  list)             cmd_list ;;
  show)             cmd_show "${2:-}" ;;
  use)              cmd_use "${2:-}" ;;
  reset)            cmd_reset ;;
  status)           cmd_status ;;
  coordinator)      cmd_coordinator "${2:-}" ;;
  install-commands) cmd_install_commands ;;
  branch)           shift; cmd_branch "$@" ;;
  help|--help|-h)   cmd_help ;;
  *) die "Unknown command: $1. Run 'claude-team help' for usage." ;;
esac
